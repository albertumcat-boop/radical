{
  "version": 2,
  "routes": [
    { "src": "/", "dest": "/landing.html" },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/landing", "dest": "/landing.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
