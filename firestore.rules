rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Campos que SOLO el backend puede escribir ──────────────────────────
    // El cliente nunca debe poder escribirse su propio tier, trialStart,
    // ni datos de suscripción. Esto elimina todos los bypasses de consola.
    function isSensitiveField(data) {
      return data.keys().hasAny([
        'tier', 'trialStart', 'subscriptionStatus',
        'stripeCustomer', 'lsSubscriptionId', 'lsVariantId'
      ]);
    }

    // ── Doc raíz del usuario: /users/{uid} ────────────────────────────────
    // Lectura: solo el propio usuario.
    // Creación: permitida solo con tier=free y sin campos sensibles de pago.
    // Update: permitido SOLO si no toca campos protegidos.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Al registrarse el cliente puede escribir: email, tier=free, trialStart, createdAt.
      // Nada más. subscriptionStatus, stripeCustomer, lsSubscriptionId, lsVariantId → bloqueados.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.tier == 'free'
        && request.resource.data.keys().hasOnly([
             'email', 'tier', 'trialStart', 'createdAt'
           ]);

      // El cliente puede actualizar atelierId, email, preferencias — pero NO campos de pago
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasAny(['tier', 'trialStart', 'subscriptionStatus',
                      'stripeCustomer', 'lsSubscriptionId', 'lsVariantId']);
    }

    // ── Subcollections del usuario: notas, sistemas, clientes, etc. ───────
    match /users/{uid}/{col}/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/{col}/{doc}/{rest=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Patrones guardados ────────────────────────────────────────────────
    match /patterns/{patternId} {
      allow read, update, delete: if request.auth != null
                                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // ── Ateliers ──────────────────────────────────────────────────────────
    match /ateliers/{atelierId} {
      allow read: if request.auth != null
                  && (resource.data.ownerUid == request.auth.uid
                      || request.auth.uid in resource.data.empleados);

      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.empleados == [request.auth.uid];

      // Dueño puede actualizar cualquier campo del atelier
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;

      // Miembro puede solo agregar/quitar su propio uid del array empleados
      allow update: if request.auth != null
                    && resource.data.ownerUid != request.auth.uid
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['empleados'])
                    && (
                         request.resource.data.empleados ==
                           resource.data.empleados.concat([request.auth.uid])
                         ||
                         (resource.data.empleados.hasAll(request.resource.data.empleados)
                          && resource.data.empleados.size() ==
                             request.resource.data.empleados.size() + 1)
                       );

      match /materiales/{matId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/ateliers/$(atelierId))
               .data.empleados.hasAny([request.auth.uid]);
      }
    }

    // ── Códigos de atelier (solo get, nunca list) ──────────────────────────
    match /atelierCodes/{codigo} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['atelierId']);
      allow update, delete: if false;
    }

    // ── Todo lo demás: denegado ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
